# Sample environment variables for Scrum Master Bot (n8n workflow)
# Copy to `.env` for local use (do not commit `.env`).

# Base URL where n8n is reachable (used to build webhook URLs)
n8nUrl=http://localhost:5678

# OpenAI
OpenAI_API_Key=YOUR_OPENAI_API_KEY
AI_Model=gpt-4o-mini

# Slack
Slack_Bot_Token=xoxb-your-slack-bot-token
Slack_Scrum_Channel=#scrum-alerts
Slack_Standups_Channel=#standups

