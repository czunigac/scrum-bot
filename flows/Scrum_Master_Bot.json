    {
      "parameters": {
        "jsCode": "const { memberName, yesterday, today, blockers } = $input.first().json;\n\nif (!memberName || !yesterday || !today) {\n  throw new Error('Missing required standup fields');\n}\n\nconst hasBlockers = blockers &&\n  blockers.toLowerCase() !== 'no' &&\n  blockers.toLowerCase() !== 'none' &&\n  blockers.trim() !== '';\n\nreturn [{\n  json: {\n    memberName,\n    yesterday,\n    today,\n    blockers: blockers || 'None',\n    hasBlockers,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -128,
        -336
      ],
      "id": "a5d37662-8dba-499a-a612-f681f00c805a",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a Scrum Master assistant. Given a team member's standup update, produce a concise professional summary.\\n\\nRespond ONLY with this exact JSON structure, no markdown, no code blocks:\\n{\\n  \\\"summary\\\": \\\"2-3 sentence professional summary\\\",\\n  \\\"status\\\": \\\"on-track | blocked | at-risk\\\",\\n  \\\"keyPoints\\\": [\\\"point 1\\\", \\\"point 2\\\"],\\n  \\\"blockerAlert\\\": \\\"description if blocked, null if not\\\"\\n}\\n\\nAlways respond in the same language as the input.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Team member: {{ $json.memberName }}\\nYesterday: {{ $json.yesterday }}\\nToday: {{ $json.today }}\\nBlockers: {{ $json.blockers }}\"\n    }\n  ],\n  \"temperature\": 0.3\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        32,
        -336
      ],
      "id": "533110fc-f1e3-42a5-8110-64cd46ce7a92",
      "name": "HTTP Request",
      "alwaysOutputData": false,
      "credentials": {
        "httpHeaderAuth": {
          "id": "PglSypl7ox33p4Fh",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// OpenAI devuelve choices, pero el nodo anterior puede tener otros campos\n// Intenta leer de diferentes fuentes\nlet aiContent = input.choices?.[0]?.message?.content || '';\naiContent = aiContent.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst ai = JSON.parse(aiContent);\n\n// Leer memberName del contexto del workflow via $('NombreNodo')\n// Primero verifica qué nodos están disponibles:\nconst allNodes = Object.keys($input);\nconsole.log('Available:', JSON.stringify(allNodes));\n\nconst statusEmoji = {\n  'on-track':  '✅',\n  'blocked':   '🚫',\n  'at-risk':   '⚠️'\n};\n\nconst emoji = statusEmoji[ai.status] || '✅';\n\nconst slackBlocks = [\n  {\n    type: \"header\",\n    text: {\n      type: \"plain_text\",\n      text: `${emoji} Standup — ${input.memberName}`\n    }\n  },\n  {\n    type: \"section\",\n    fields: [\n      { type: \"mrkdwn\", text: `*Status:*\\n${ai.status.toUpperCase()}` },\n      { type: \"mrkdwn\", text: `*Time:*\\n<!date^${Math.floor(Date.now()/1000)}^{time}|now>` }\n    ]\n  },\n  {\n    type: \"section\",\n    text: { type: \"mrkdwn\", text: `*Summary:*\\n${ai.summary}` }\n  },\n  {\n    type: \"section\",\n    text: {\n      type: \"mrkdwn\",\n      text: `*Key points:*\\n${ai.keyPoints.map(p => `• ${p}`).join('\\n')}`\n    }\n  },\n  { type: \"divider\" }\n];\n\nreturn [{\n  json: {\n    memberName: input.memberName,\n    status: ai.status,\n    hasBlocker: !!ai.blockerAlert,\n    blockerAlert: ai.blockerAlert,\n    slackBlocks,\n    slackText: `${emoji} Standup from ${input.memberName}: ${ai.summary}`\n  }\n}];"
      },
